  <data name="customSqlQuery2.Sql" xml:space="preserve">
    <value>select c.MALZEME_MATERYAL as 'Malzeme Kodu', c.MALZEME_RAFNO as 'Malzeme Raf No', c.MALZEME_ADI as 'Malzeme Cinsi', e.MALZEME_DEPARTMANADI,
b.MALZEMEISTEM_ADET as 'Verilen Miktar', case when c.MALZEME_OLCUBIRIMI=1 then 'ADET' when c.MALZEME_OLCUBIRIMI=2 then 'METRE' else '' 
end 'Ölçü Birimi', 
(isnull(mg.GirislerToplam,0) - isnull(mc.CikislarToplam,0)) as  'Mevcut Miktar',
a.MALZEMEDEPOISTEM_ISTEMTARIHI, b.MALZEMEISTEM_MALZEMEDEPOISTEMID,  a.MALZEMEDEPOISTEM_ID, b.MALZEMEISTEM_DURUM, d.MALZEMEKULLANICI_ADI 
from TBL_LST_MALZEMEDEPOISTEM a (nolock)
INNER join TBL_LST_MALZEMEISTEM b  (nolock) on a.MALZEMEDEPOISTEM_ID=b.MALZEMEISTEM_MALZEMEDEPOISTEMID 
INNER join TBL_LST_MALZEMELER c (nolock) on b.MALZEMEISTEM_MALZEMELERID = c.MALZEME_ID
INNER join TBL_LST_MALZEMEKULLANICILAR d (nolock) on a.MALZEMEDEPOISTEM_KULLANICIID=d.MALZEMEKULLANICI_ID
INNER join TBL_LST_MALZEMEDEPARTMANLAR e (nolock) on b.MALZEMEISTEM_MALZEMEDEPARTMANISTEMID=e.MALZEME_DEPARTMANID
LEFT OUTER JOIN (Select  MALZEMEGIRIS_MALZEMELERID, Sum(MALZEMEGIRIS_ADET) GirislerToplam  
FROM TBL_LST_MALZEMEGIRIS GROUP BY  MALZEMEGIRIS_MALZEMELERID ) mg ON mg.MALZEMEGIRIS_MALZEMELERID = c.MALZEME_ID 
LEFT OUTER JOIN (Select  MALZEMECIKIS_MALZEMELERID, Sum(MALZEMECIKIS_ADET) CikislarToplam  FROM TBL_LST_MALZEMECIKIS 
GROUP BY  MALZEMECIKIS_MALZEMELERID ) mc ON mc.MALZEMECIKIS_MALZEMELERID = c.MALZEME_ID
where isnull(a.MALZEMEDEPOISTEM_DURUM,0)&lt;&gt;2 and isnull(b.MALZEMEISTEM_DURUM,0)&lt;&gt;2 order by 2</value>
